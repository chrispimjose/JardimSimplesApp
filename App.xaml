<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:JardimSimplesApp"
             x:Class="JardimSimplesApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="VerdePrincipal">#2E7D32</Color>
            <Color x:Key="VerdeSecundario">#66BB6A</Color>
            <Color x:Key="VerdeClaro">#E8F5E9</Color>
            <Color x:Key="VerdeTexto">#1B5E20</Color>
            <Color x:Key="Branco">#FFFFFF</Color>
            <Color x:Key="CinzaSuave">#F7F7F7</Color>
            <Color x:Key="VermelhoSuave">#C62828</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource CinzaSuave}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource VerdeTexto}" />
                <Setter Property="FontSize" Value="16" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource VerdePrincipal}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="Black" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="Black" />
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="Black" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
