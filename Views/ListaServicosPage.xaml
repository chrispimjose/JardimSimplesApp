<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JardimSimplesApp.Views.ListaServicosPage"
             Title="Serviços de Jardinagem">

    <!-- Página de listagem de serviços -->

        <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="12">

            <!-- Título -->
            <Label Text="Controle de Serviços"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{StaticResource VerdePrincipal}" />

            <!-- Botões -->
            <HorizontalStackLayout Grid.Row="1" Spacing="3" HorizontalOptions="Center">
                <Button Text="Novo Serviço"
                        Clicked="OnNovoServicoClicked"
                        HorizontalOptions="FillAndExpand"
                        Shadow="#000000 1 4"/>

                <Button Text="Editar Selecionado"
                        Clicked="OnEditarServicoClicked"
                        TextColor="DarkGreen"
                        BackgroundColor="{StaticResource VerdeSecundario}"
                        HorizontalOptions="FillAndExpand" 
                        Shadow="#000000 1 4"/>
                <Button Text="Excluir Item"
                        Clicked="OnExcluirServicoClicked"
                        BackgroundColor="Red"
                        TextColor="White"
                        HorizontalOptions="FillAndExpand" 
                        Shadow="#000000 1 4"/>
        </HorizontalStackLayout>

            <!-- Lista -->
        <CollectionView 
                    Grid.Row="2"
                    x:Name="ServicosCollectionView"
                    SelectionMode="Single"
                    SelectionChanged="OnServicoSelectionChanged">
            

                <CollectionView.EmptyView>
                    <ContentView>
                        <Label  Text="Nenhum serviço cadastrado."
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                    </ContentView>                   
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                    <Border Stroke="DarkGreen"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource VerdeClaro}"
                            StrokeShape="RoundRectangle 12"
                            Margin="3"
                            Padding="20"
                            >
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal" />
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <!-- >>> ALTERAÇÃO: destaque visual do item selecionado -->
                                        <Setter Property="BackgroundColor" Value="LightGreen" />
                                        <Setter Property="Stroke" Value="DarkGreen" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Cliente}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource VerdePrincipal}" />

                                <Label Text="{Binding TipoServico, StringFormat='Serviço: {0}'}" />
                                <Label Text="{Binding Endereco, StringFormat='Endereço: {0}'}" />
                                <Label Text="{Binding DataServico, StringFormat='Data: {0:dd/MM/yyyy}'}" />
                                <Label Text="{Binding Valor, StringFormat='Valor: R$ {0:F2}'}" />
                                <Label Text="{Binding Status, StringFormat='Status: {0}'}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
</ContentPage>