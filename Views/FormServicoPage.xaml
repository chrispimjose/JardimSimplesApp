<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JardimSimplesApp.Views.FormServicoPage"
             Title="Cadastro de Serviço">
    
    <ScrollView>
        
        <!-- Formulário de cadastro/edição de serviço -->
            
            <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Cadastro / Edição de Serviço"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource VerdePrincipal}" />
            <Label Text="Cliente" />
            
            <Entry x:Name="ClienteEntry"
                   Placeholder="Digite o nome do cliente" />
            
            <Label Text="Tipo de serviço" />            
            <Entry x:Name="TipoServicoEntry"
                   Placeholder="Ex.: Corte de grama" />
            
            <Label Text="Endereço" />            
            <Entry x:Name="EnderecoEntry"
                   Placeholder="Digite o endereço do serviço" />
            
            <Label Text="Data do serviço" />
            <DatePicker x:Name="DataServicoPicker" />
            
            <Label Text="Valor" />
            <Entry x:Name="ValorEntry"
                   Placeholder="Digite o valor"
                   Keyboard="Numeric" />
            
            <Label Text="Status" />
            <Picker x:Name="StatusPicker"
                    Title="Selecione o status">
                <Picker.Items>
                    <x:String>Agendado</x:String>
                    <x:String>Em andamento</x:String>
                    <x:String>Concluído</x:String>
                </Picker.Items>
            </Picker>
            
            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                <Button Text="Salvar"
                        Clicked="OnSalvarClicked"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="Cancelar"
                        Clicked="OnCancelarClicked"
                        HorizontalOptions="FillAndExpand" />
                
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>